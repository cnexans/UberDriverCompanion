<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#1B1B1B">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Uber Analyzer"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servicio: Inactivo"
                android:textColor="#FF5252"
                android:textSize="14sp"
                android:paddingTop="4dp" />

            <!-- Permission buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccessibility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Accesibilidad"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOverlay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Permiso Overlay"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Show/Hide overlay toggle -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mostrar Overlay"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Thresholds -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Umbrales de color"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Define cuando un viaje se muestra verde, amarillo o rojo."
                android:textColor="#888888"
                android:textSize="12sp"
                android:paddingBottom="16dp" />

            <!-- $/km thresholds -->
            <include layout="@layout/threshold_row"
                android:id="@+id/thresholdKm" />

            <!-- $/hora thresholds -->
            <include layout="@layout/threshold_row"
                android:id="@+id/thresholdHora" />

            <!-- % dist thresholds -->
            <include layout="@layout/threshold_row"
                android:id="@+id/thresholdPct" />

        </LinearLayout>

        <!-- Remove Ads button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveAds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quitar anuncios"
            android:textSize="14sp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- AdMob Banner -->
        <com.google.android.gms.ads.AdView
            android:id="@+id/adView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            ads:adSize="BANNER"
            ads:adUnitId="ca-app-pub-5847552354932898/1297636033"
            xmlns:ads="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>
</ScrollView>
